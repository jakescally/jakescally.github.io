---
import { Image } from "astro:assets";

import DrinkRecipePanel from "@/components/DrinkRecipePanel.astro";
import DrinksLayout from "@/layouts/DrinksLayout.astro";
import { requireImage } from "@/lib/assets";
import { barMeta } from "@/lib/bar";
import { getDrinkBySlug, getPublishedDrinks } from "@/lib/drinks";

export function getStaticPaths() {
  return getPublishedDrinks().map((entry) => ({
    params: { slug: entry.data.slug }
  }));
}

const entry = getDrinkBySlug(Astro.params.slug);

if (!entry) {
  throw new Error(`Missing drink entry: ${Astro.params.slug}`);
}

const Content = entry.Content;
const heroImage = entry.data.heroImage ? requireImage(entry.data.heroImage) : undefined;
---

<DrinksLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.heroImage}
  bodyClass="page-bar-detail"
>
  <article class="frame drink-detail">
    <div class="drink-detail__frame">
      <section class="drink-detail__paper">
        <div class="drink-detail__masthead">
          <p class="drink-detail__eyebrow">{barMeta.eyebrow}</p>
          <a class="drink-detail__back" href="/bar/">
            Back to menu
          </a>
        </div>

        <div class="drink-detail__hero">
          <div class="drink-detail__copy">
            <h1>{entry.data.title}</h1>
            <p class="drink-detail__description">{entry.data.description}</p>
            <div class="drink-detail__meta">
              <span>{entry.data.menuSection}</span>
              <span>{entry.data.baseSpirit}</span>
              {entry.data.method && <span>{entry.data.method}</span>}
              {entry.data.garnish && <span>{entry.data.garnish}</span>}
            </div>
          </div>

          <div class:list={["drink-detail__image", !heroImage && "drink-detail__image--placeholder"]}>
            {heroImage ? (
              <Image
                src={heroImage}
                alt={entry.data.title}
                widths={[720, 1080, 1440]}
                sizes="(min-width: 1120px) 28rem, 100vw"
              />
            ) : (
              <>
                <p>{entry.data.baseSpirit}</p>
                <span>{entry.data.menuSection}</span>
              </>
            )}
          </div>
        </div>

        <div class="drink-detail__content">
          <DrinkRecipePanel entry={entry} />
          <div class="drink-detail__story prose">
            <Content />
          </div>
        </div>
      </section>
    </div>
  </article>
</DrinksLayout>
