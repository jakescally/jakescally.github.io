---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-heading">
  {eyebrow && <p class="page-heading__eyebrow">{eyebrow}</p>}
  <h1 class="page-heading__title">{title}</h1>
  {description && <p class="page-heading__description">{description}</p>}
</header>
