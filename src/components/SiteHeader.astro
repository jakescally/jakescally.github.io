---
import wordmark from "@/assets/brand/scallynetwork.png";
import WhiskyGlassIcon from "@/components/WhiskyGlassIcon.astro";

interface Props {
  showSearch?: boolean;
}

const currentPath = Astro.url.pathname;
const { showSearch = true } = Astro.props;
const isBarPage = currentPath.startsWith("/bar/");

const navItems = [
  { href: "/", label: "Home" },
  { href: "/writing/", label: "Writing" },
  { href: "/projects/", label: "Projects" },
  { href: "/photography/", label: "Photography" },
  { href: "/about/", label: "About" }
];
---

<header class="site-header" data-site-header>
  <div class="site-header__inner frame">
    <a class="site-header__brand" href="/" aria-label="Scally Network home">
      <img src={wordmark.src} alt="Scally Network" />
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={["site-header__link", currentPath === item.href && "is-active"]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/bar/"
        aria-label="Bar menu"
        class:list={[
          "site-header__link",
          "site-header__icon-link",
          isBarPage && "is-active"
        ]}
      >
        <WhiskyGlassIcon className="site-header__icon" />
      </a>
      {showSearch && (
        <button class="site-header__search" type="button" data-open-search>
          Search
        </button>
      )}
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector("[data-site-header]");

  const syncHeaderState = () => {
    if (!header) {
      return;
    }

    header.toggleAttribute("data-condensed", window.scrollY > 20);
  };

  syncHeaderState();
  window.addEventListener("scroll", syncHeaderState, { passive: true });
</script>
